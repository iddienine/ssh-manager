    local i=0
    while kill -0 $pid 2>/dev/null; do
        printf "\r${GREEN}[%s] %s${NC}" "${spin[$i++ % ${#spin[@]}]}" "$1"
        sleep .1
    done
    printf "\r${GREEN}вњ… %s... Done!${NC}\n" "$1"
}

